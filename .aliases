# eza
alias ls='eza --icons'
alias ll='eza -lah --icons'
alias lt='eza --tree --icons'

# bat
alias b='bat'

# lazygit
alias lg='lazygit'

# Common shortcuts
alias s='ssh'
alias df='df -h'
alias du1='du -h -d=1'

# Shell reload — `exec zsh` replaces the current shell process (clean reload)
alias zr='exec zsh'

# Per-remote git pull/push (omz git plugin has `gpu` for `git push upstream`,
# and `gluc`/`glum` for pulling upstream)
alias gln='git pull neiljdo'
alias gpn='git push neiljdo'
# alias glh='git pull gh'
# alias glu='git pull upstream'
# alias gph='git push gh'

# Global pipe aliases
alias -g L='| less'
alias -g G='| grep'
alias -g H='| head'
alias -g T='| tail'
alias -g F='| tail -f'
alias -g J='| jq'
alias -g Y='| yq'
alias -g C='| pbcopy'
alias -g NUL='> /dev/null 2>&1'

# brew
alias bupf='brew upgrade --formula'
alias -g bupcg='brew upgrade --cask --greedy'
alias bupcgd='bupcg --dry-run'